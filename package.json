{
  "name": "texas-holdem-poker",
  "version": "1.0.0",
  "description": "单机德州扑克游戏",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "test": "node tests/gameLogic.test.js",
    "test:unit": "vitest run",
    "lint": "eslint --ext .js,.vue src tests",
    "lint:fix": "eslint --fix --ext .js,.vue src tests",
    "format": "prettier --write \"**/*.{js,vue,json,css,md}\"",
    "build": "vite build",
    "preview": "vite preview",
    "coverage": "vitest run --coverage",
    "deploy": "gh-pages -d holdem"
  },
  "dependencies": {
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.3",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.33.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.8.1",
    "vite": "7.1.11",
    "vitest": "^1.6.1"
  }
}
